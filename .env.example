# Formspree endpoint used by the Order Request and Contact forms.
# Sign up at https://formspree.io, create a form, and paste its endpoint URL here.
# If this is left unset, form submissions fall back to a console.log (see
# components/OrderRequestForm.tsx and app/contact/ContactClient.tsx for the
# commented-out mailto: fallback you can enable instead).
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/yourFormId

# --- Admin Panel (/admin-requests) -----------------------------------------
# Used ONLY by netlify/functions/get-submissions.ts (a server-side Netlify
# Function), never exposed to the browser. These let the owner view Order
# Request form submissions at /admin-requests without checking email.
#
# NETLIFY_API_TOKEN: a personal access token, generated at
#   Netlify dashboard -> User settings (click your avatar) -> Applications ->
#   Personal access tokens -> New access token. Copy it immediately (it's
#   only shown once) and add it as an environment variable with this same
#   name under Site settings -> Environment variables in the Netlify
#   dashboard (do NOT put your real token in this .env.example file or
#   commit it anywhere).
NETLIFY_API_TOKEN=

# NETLIFY_SITE_ID: this site's Site ID (a UUID), found at
#   Site settings -> General -> Site details -> Site ID. Add it the same way,
#   as an environment variable in the Netlify dashboard.
NETLIFY_SITE_ID=
